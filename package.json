{
  "name": "@lpm-registry/cli",
  "version": "0.2.0",
  "description": "CLI for Licensed Package Manager",
  "author": "LPM <hello@lpm.dev> (https://lpm.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/lpm-dev/cli"
  },
  "homepage": "https://lpm.dev",
  "license": "ISC",
  "keywords": [
    "lpm",
    "package-manager",
    "registry",
    "npm",
    "private-packages"
  ],
  "main": "index.js",
  "bin": {
    "lpm": "./bin/lpm.js"
  },
  "exports": {
    ".": "./index.js",
    "./lib/*": "./lib/*"
  },
  "types": "./index.d.ts",
  "sideEffects": false,
  "files": [
    "bin",
    "lib",
    "index.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "conf": "^12.0.0",
    "diff": "^8.0.2",
    "inquirer": "^9.2.12",
    "open": "^11.0.0",
    "ora": "^8.2.0",
    "semver": "^7.7.3",
    "tar": "^7.5.2",
    "update-notifier": "^7.3.1"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
